# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# URL file playlist M3U8 (wajib)
VITE_M3U_URL=https://fireredst.github.io/Itz-Play/Play.m3u

# VPS Proxy URL (opsional, isi jika punya VPS proxy sendiri)
# Contoh: https://proxy.domainmu.com
VITE_VPS_PROXY_URL=

# Cloudflare Worker URL (opsional fallback)
# Contoh: https://live-proxy.namaanda.workers.dev
VITE_CF_WORKER_URL=
